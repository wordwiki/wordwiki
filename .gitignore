/web-build/*

# The default instance directory (data: db, content/derived/imports, the
# published static site, runtime files) - ~66GB, never tracked.  Other
# instances live elsewhere via WORDWIKI_DIR.
/mmo/

# Per-checkout port pins for the run scripts (overridden by the *_PORT env vars).
/wordwiki_port.txt
/rabid_port.txt

# Per-checkout "current unit of work" label (read by the Emacs modeline chip).
/current-task.txt

# Runtime files written by the rabid server at startup (see Rabid.startServer).
/rabid.pid
/rabid-shutdown-password.txt
/rabid-eval-password.txt
