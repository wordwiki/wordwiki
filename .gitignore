/web-build/*

# PLAINTEXT team passwords ({username: password} JSON, loaded by
# post-pull/upgrade-users - see user.seedPasswordsFromFile).  Never tracked.
/user-passwords.json

# The default instance directory (data: db, content/derived/imports, the
# published static site, runtime files) - ~66GB, never tracked.  Other
# instances live elsewhere via WORDWIKI_DIR.
/mmo/

# Per-checkout port pins for the run scripts (overridden by the *_PORT env vars).
/wordwiki_port.txt
/rabid_port.txt

# Per-checkout "current unit of work" label (read by the Emacs modeline chip).
/current-task.txt

# Runtime files written by the rabid server at startup (see Rabid.startServer).
# (wordwiki's equivalents live in its instance dir, /mmo/, already ignored above.)
/rabid.pid
/rabid-shutdown-password.txt
/rabid-eval-password.txt
/rabid-base-url.txt

# Mail credential (SMTP app password etc.) for liminal/mail.ts - NEVER commit.
/rabid-mail-credential.json
/wordwiki-mail-credential.json

# The rabid dev database (rebuilt by rabid_create_fake_data.sh at the repo
# root); throwaway fake data, never tracked.
/database/
/.claude-home/
